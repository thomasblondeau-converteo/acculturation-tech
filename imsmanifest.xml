<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCORM 1.2 manifest for: Le Voyage de la Donnée — Converteo Tech Academy
  - One organization, one SCO (the launchable item), tracked for completion.
  - index.html is declared as the SCO resource (scormtype="sco"), not an asset.
-->
<manifest identifier="CONVERTEO_VOYAGE_DONNEE_MANIFEST"
          version="1.2"
          xmlns="http://www.imsproject.org/xsd/imscp_rootv1p1p2"
          xmlns:adlcp="http://www.adlnet.org/xsd/adlcp_rootv1p2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.imsproject.org/xsd/imscp_rootv1p1p2 imscp_rootv1p1p2.xsd
                              http://www.imsglobal.org/xsd/imsmd_rootv1p2p1 imsmd_rootv1p2p1.xsd
                              http://www.adlnet.org/xsd/adlcp_rootv1p2 adlcp_rootv1p2.xsd">

  <metadata>
    <schema>ADL SCORM</schema>
    <schemaversion>1.2</schemaversion>
  </metadata>

  <organizations default="CONVERTEO_ORG">
    <organization identifier="CONVERTEO_ORG">
      <title>Le Voyage de la Donnée — Converteo Tech Academy</title>
      <item identifier="ITEM_VOYAGE_DONNEE" identifierref="RES_VOYAGE_DONNEE" isvisible="true">
        <title>Le Voyage de la Donnée</title>
        <!-- Completion is driven by the SCO at runtime (lesson_status / score). -->
        <adlcp:masteryscore>70</adlcp:masteryscore>
      </item>
    </organization>
  </organizations>

  <resources>
    <resource identifier="RES_VOYAGE_DONNEE"
              type="webcontent"
              adlcp:scormtype="sco"
              href="index.html">
      <file href="index.html"/>
      <file href="scorm-api.js"/>
    </resource>
  </resources>

</manifest>
